{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "C++ Demo (MSVC / cppvsdbg)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build_msvc/Debug/demo.exe",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "environment": [],
            "console": "integratedTerminal"
        },
        {
            "name": "C++ Demo (GCC / cppdbg + gdb)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build_gcc/demo",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "MIMode": "gdb",
            "miDebuggerPath": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "C++ Demo (LLVM / cppdbg + lldb-mi)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build_llvm/demo",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "MIMode": "lldb"
        },
        {
            "name": "C++ Demo (LLVM / CodeLLDB)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build_llvm/demo",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopOnEntry": false
        }
    ]
}
